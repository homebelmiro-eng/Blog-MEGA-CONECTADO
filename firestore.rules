rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety helpers to ensure robust authentication and role checking
    function isSignedIn() {
      return request.auth != null;
    }
    
    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isRole(roles) {
      return isSignedIn() && hasUserDoc() && (getUserRole() in roles);
    }

    // Articles Rules: public read, write restricted to authorised staff, public view increment allowed
    match /articles/{articleId} {
      allow read: if true;
      allow create: if isRole(['admin', 'editor', 'author']);
      allow update: if isRole(['admin', 'editor', 'author']) || 
                    (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['views']));
      allow delete: if isRole(['admin']);
    }
    
    match /categories/{catId} {
      allow read: if true;
      allow write: if isRole(['admin']);
    }

    match /authors/{authorId} {
      allow read: if true;
      allow write: if isRole(['admin']);
    }

    match /users/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && (request.auth.uid == userId || isRole(['admin']));
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isRole(['admin']);
    }
  }
}
